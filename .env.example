# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_user_id_here

# LLM Configuration
ANTHROPIC_API_KEY=your_anthropic_key_here

# Audio Transcription Configuration
GROQ_API_KEY=your_groq_api_key_here

# --- Manual editor (/edit) ---
#
# Shared token used by adapters (CLI/Telegram/eval) to talk to core. When
# set, core starts requiring a bearer on write endpoints. Adapters pick it
# up automatically from this env var.
PALIO_CORE_TOKEN=
#
# Firebase Google sign-in for the web editor. If
# website/firebase-config.json exists (downloaded from the Firebase console),
# the projectId/apiKey/authDomain/appId are auto-loaded from there and
# the env vars below can stay empty. Set FIREBASE_CONFIG_PATH to
# override the default location.
FIREBASE_CONFIG_PATH=
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=
# Comma-separated Google account emails allowed to sign in. REQUIRED for
# a public deployment — leaving this empty means any Google account can
# sign in. Set it to your own email.
EDITOR_ALLOWED_EMAILS=