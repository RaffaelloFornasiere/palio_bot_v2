        "palio_games_status.json": [
          { "path": "$.game_scores.G05.status", "set": "completed" },
          { "path": "$.game_scores.G05.divisions[0].status", "set": "completed" },
          { "path": "$.game_scores.G05.divisions[0].scores", "set": {
            "Salt": 12, "Sottocastello": 10, "Villa": 9, "Sornico": 11, "Sottomonte": 13
          }}
        ]
      }
    },
    {
      "id": "s9_cancel_penalty",
      "prompt": "annulla il bonus di Sornico sull'Anguria (era sbagliato)",
      "changes": {
        "palio_games_status.json": [
          { "path": "$.game_scores.G03.divisions[0].applied_bonuses", "set": [] }
        ]
      }
    },
    {
      "id": "s10_summary",
      "prompt": "riepiloga quali giochi sono completati finora"
