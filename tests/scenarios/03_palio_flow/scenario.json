{
  "name": "evening_of_palio",
  "reset_between_steps": false,
  "seed": {
    "palio.json": "seeds/palio.json",
    "leaderboard.json": "seeds/leaderboard.json",
    "palio_games_status.json": "seeds/palio_games_status.json"
  },
  "steps": [
    {
      "id": "s1_inventory",
      "prompt": "elenca i giochi disponibili e indicami il loro stato attuale"
    },
    {
      "id": "s2_taglio_start",
      "prompt": "Il Taglio del Tronco inizia. Metti sia il gioco sia entrambe le divisioni a 'in-progress'.",
      "changes": {
        "palio_games_status.json": [
          { "path": "$.game_scores.G01.status", "set": "in-progress" },
          { "path": "$.game_scores.G01.divisions[0].status", "set": "in-progress" },
          { "path": "$.game_scores.G01.divisions[1].status", "set": "in-progress" }
        ]
      }
    },
    {
      "id": "s3_taglio_complete",
      "prompt": "Taglio del Tronco è terminato. Marca il gioco e le divisioni come completati.",
      "changes": {
        "palio_games_status.json": [
          { "path": "$.game_scores.G01.divisions[0].status", "set": "completed" },
          { "path": "$.game_scores.G01.divisions[1].status", "set": "completed" },
          { "path": "$.game_scores.G01.status", "set": "completed" }
        ]
      }
    },
    {
      "id": "s4_corsa_sacchi_mens",
