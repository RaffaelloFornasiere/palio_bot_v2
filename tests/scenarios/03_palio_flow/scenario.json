        "palio_games_status.json": [
          { "path": "$.game_scores.G02.status", "set": "in-progress" },
          { "path": "$.game_scores.G02.divisions[0].status", "set": "completed" },
          { "path": "$.game_scores.G02.divisions[0].scores", "set": {
            "Salt": 30, "Sottocastello": 28, "Villa": 35, "Sornico": 32, "Sottomonte": 31
          }}
        ]
      }
    },
    {
      "id": "s5_corsa_sacchi_women",
      "prompt": "Corsa coi Sacchi femminile: Salt 34, Sottocastello 32, Villa 40, Sornico 33, Sottomonte 36. Completa la divisione e il gioco.",
      "changes": {
        "palio_games_status.json": [
          { "path": "$.game_scores.G02.divisions[1].status", "set": "completed" },
          { "path": "$.game_scores.G02.divisions[1].scores", "set": {
            "Salt": 34, "Sottocastello": 32, "Villa": 40, "Sornico": 33, "Sottomonte": 36
          }},
          { "path": "$.game_scores.G02.status", "set": "completed" }
        ]
      }
    },
    {
      "id": "s6_anguria_bonus",
      "prompt": "Imposta l'Anguria a 'in-progress' e assegna un bonus di 3 punti di classifica a Sornico nella divisione maschile per buona condotta.",
      "changes": {
        "palio_games_status.json": [
          { "path": "$.game_scores.G03.status", "set": "in-progress" },
          { "path": "$.game_scores.G03.divisions[0].applied_bonuses", "set": [
            { "village": "Sornico", "description": "buona condotta", "points": 3 }
          ]}
        ]
      }
    },
    {
      "id": "s7_scatolone_start",
      "prompt": "Lo Scatolone inizia. Metti il gioco e le due divisioni a 'in-progress'.",
      "changes": {
        "palio_games_status.json": [
          { "path": "$.game_scores.G04.status", "set": "in-progress" },
          { "path": "$.game_scores.G04.divisions[0].status", "set": "in-progress" },
          { "path": "$.game_scores.G04.divisions[1].status", "set": "in-progress" }
